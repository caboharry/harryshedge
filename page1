<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Harry's Hedge — Sign Up</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    width: 100%;
    height: 100%;
    overflow: hidden;
    font-family: 'DM Sans', sans-serif;
  }

  body {
    background: url('data:image/png;base64,') no-repeat center center / cover;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
  }

  .card {
    isolation: isolate;
    width: 480px;
    max-width: 90vw;
    border-radius: 20px;
    padding: 50px 48px 42px;
    display: flex;
    flex-direction: column;
    align-items: center;
    background: rgba(28, 50, 35, 0.52);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(255,255,255,0.13);
    box-shadow: none;
    transform: translateZ(0);
  }

  .brand {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.5rem;
    font-weight: 400;
    color: #f0ede8;
    text-align: center;
    margin-bottom: 7px;
  }

  .tagline {
    font-size: 0.81rem;
    font-weight: 300;
    color: rgba(240,237,232,0.60);
    letter-spacing: 0.04em;
    text-align: center;
    margin-bottom: 30px;
  }

  input {
    width: 100%;
    background: rgba(255,255,255,0.10);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 50px;
    padding: 13px 20px;
    color: #f0ede8;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.87rem;
    font-weight: 300;
    outline: none;
    margin-bottom: 11px;
    box-shadow: none;
    -webkit-appearance: none;
  }
  input::placeholder { color: rgba(240,237,232,0.38); }
  input:focus { border-color: rgba(255,255,255,0.36); background: rgba(255,255,255,0.15); }
  input:last-of-type { margin-bottom: 0; }

  .btn {
    width: 100%;
    margin-top: 20px;
    padding: 14px;
    background: rgba(245,242,236,0.92);
    color: #1a2e1e;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.90rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    border: none;
    border-radius: 50px;
    cursor: pointer;
    -webkit-appearance: none;
  }
  .btn:hover { background: #fff; }

  .login-line {
    margin-top: 16px;
    font-size: 0.80rem;
    font-weight: 300;
    color: rgba(240,237,232,0.52);
    text-align: center;
  }
  .login-line a { color: rgba(240,237,232,0.88); text-decoration: underline; cursor: pointer; }

  .free-note {
    margin-top: 7px;
    font-size: 0.72rem;
    font-weight: 300;
    color: rgba(240,237,232,0.28);
    text-align: center;
  }
</style>
</head>
<body>
  <div class="card">
    <div class="brand">Harry's Hedge</div>
    <div class="tagline">Curated positions. Controlled access. Real upside.</div>
    <input type="text"     placeholder="Full Name"        autocomplete="name">
    <input type="email"    placeholder="Email"            autocomplete="email">
    <input type="password" placeholder="Password"         autocomplete="new-password">
    <input type="password" placeholder="Confirm Password" autocomplete="new-password">
    <button class="btn">Create Account</button>
    <div class="login-line">Already have an account? <a href="#">Log in</a></div>
    <div class="free-note">Free access included. Upgrade anytime</div>
  </div>
</body>
</html>
